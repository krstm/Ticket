{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] ({CorrelationId}) {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:O} [{Level:u3}] ({CorrelationId}) {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
    "ConnectionStrings": {
        "TicketDb": "Server=localhost\\SQLEXPRESS;Database=TicketDb;Trusted_Connection=True;TrustServerCertificate=True;"
    },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "ApiKeys": {
    "CategoryManagement": "SET-THIS-IN-SECRETS"
  },
  "AllowedHosts": "*",
  "Notifications": {
    "NotifyOnTicketCreated": false,
    "NotifyOnTicketResolved": false,
    "PreferredChannel": "log"
  }
}