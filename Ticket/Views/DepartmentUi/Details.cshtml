@model Ticket.DTOs.Responses.DepartmentDto
@{
    ViewData["Title"] = $"Department {Model.Name}";
}

<div class="space-y-8 max-w-3xl">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-sm text-slate-500 uppercase tracking-widest">Department</p>
            <h2 class="text-3xl font-bold text-slate-900">@Model.Name</h2>
            <p class="text-slate-500 mt-2">@Model.Description</p>
        </div>
        <a asp-controller="DepartmentUi" asp-action="Index" class="btn btn-secondary text-sm">Back to list</a>
    </div>

    <div class="card p-6">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-4">Members</h3>
        <div class="space-y-4">
            @foreach (var member in Model.Members)
            {
                <div class="flex items-center justify-between p-4 border border-slate-100 rounded-xl">
                    <div>
                        <p class="text-base font-semibold text-slate-900">@member.FullName</p>
                        <p class="text-sm text-slate-500">@member.Email</p>
                    </div>
                    <div class="text-xs text-slate-500 uppercase tracking-widest">
                        @(member.IsActive ? "Active" : "Inactive")
                    </div>
                </div>
            }
            @if (!Model.Members.Any())
            {
                <p class="text-slate-400 text-sm">No members configured.</p>
            }
        </div>
    </div>
</div>
