@model Ticket.DTOs.Responses.TicketDetailsDto
@using Ticket.Domain.Enums
@{
    ViewData["Title"] = $"Request {Model.ReferenceCode}";

    string GetPriorityClass(TicketPriority priority) => priority switch
    {
        TicketPriority.Critical => "text-red-700 bg-red-50 ring-red-600/20",
        TicketPriority.High => "text-orange-700 bg-orange-50 ring-orange-600/20",
        TicketPriority.Medium => "text-blue-700 bg-blue-50 ring-blue-600/20",
        _ => "text-slate-600 bg-slate-50 ring-slate-500/10"
    };

    string GetStatusClass(TicketStatus status) => status switch
    {
        TicketStatus.New => "bg-indigo-100 text-indigo-700",
        TicketStatus.InProgress => "bg-amber-100 text-amber-700",
        TicketStatus.Resolved => "bg-emerald-100 text-emerald-700",
        TicketStatus.Closed => "bg-slate-100 text-slate-700",
        TicketStatus.Rejected => "bg-rose-100 text-rose-700",
        _ => "bg-slate-100 text-slate-700"
    };
}

<div x-data="ticketDetailsPage({ ticketId: '@Model.Id', rowVersion: '@Convert.ToBase64String(Model.RowVersion)' })">
    <!-- Header Area -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="min-w-0">
            <div class="flex items-center gap-3 mb-2">
                <span class="text-sm font-bold text-primary-600 tracking-tight uppercase">@Model.ReferenceCode</span>
                <span class="text-slate-300">/</span>
                <span class="text-sm font-medium text-slate-500">@Model.CategoryName</span>
            </div>
            <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight leading-none">@Model.Title</h2>
        </div>
        <div class="flex items-center gap-3">
            <span class="badge @GetPriorityClass(Model.Priority) py-1.5 px-3 uppercase tracking-wider">@Model.Priority</span>
            <span class="badge @GetStatusClass(Model.Status) py-1.5 px-3 uppercase tracking-wider">@Model.Status</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Description Card -->
            <div class="card p-8">
                <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Description</h3>
                <div class="prose prose-slate max-w-none text-slate-800 leading-relaxed">
                    @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                </div>
            </div>

            <!-- Timeline / Conversation -->
            <div>
                <h3 class="flex items-center text-sm font-bold text-slate-900 mb-6">
                    <svg class="w-5 h-5 mr-2 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Activity Timeline
                </h3>
                
                <div class="flow-root">
                    <ul class="-mb-8">
                        @foreach (var eventItem in Model.History.OrderByDescending(h => h.OccurredAtUtc))
                        {
                            <li>
                                <div class="relative pb-8">
                                    <span class="absolute left-5 top-5 -ml-px h-full w-0.5 bg-slate-200" aria-hidden="true"></span>
                                    <div class="relative flex items-start space-x-3">
                                        <!-- Avatar / Icon -->
                                        <div class="relative">
                                            <div class="h-10 w-10 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-400 group-hover:border-primary-500 transition-colors z-10 bg-white">
                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                            </div>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <div>
                                                <div class="text-sm font-bold text-slate-900">@eventItem.ChangedBy</div>
                                                <p class="mt-0.5 text-xs text-slate-500">
                                                    @eventItem.OccurredAtUtc.ToLocalTime().ToString("f")
                                                </p>
                                            </div>
                                            <div class="mt-2 text-sm text-slate-700 bg-slate-50/50 rounded-xl p-4 border border-slate-100">
                                                <span class="font-semibold text-primary-700">@eventItem.Action</span>
                                                @if (!string.IsNullOrEmpty(eventItem.Note))
                                                {
                                                    <p class="mt-2 text-slate-600 italic">"@eventItem.Note"</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Comments -->
            <div class="card p-8 space-y-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Collaboration Feed</h3>
                    <span class="text-xs text-slate-400">@Model.Comments.Count comment(s)</span>
                </div>

                <div class="space-y-4">
                    @if (!Model.Comments.Any())
                    {
                        <p class="text-sm text-slate-500 italic">No comments yet. Be the first to add context.</p>
                    }
                    else
                    {
                        foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAtUtc))
                        {
                            <div class="border border-slate-100 rounded-xl p-4 bg-white">
                                <div class="flex items-center justify-between text-xs text-slate-500">
                                    <div class="font-semibold text-slate-800">@comment.AuthorDisplayName (@comment.Source)</div>
                                    <time>@comment.CreatedAtUtc.ToLocalTime().ToString("g")</time>
                                </div>
                                <p class="mt-2 text-sm text-slate-700">@comment.Body</p>
                            </div>
                        }
                    }
                </div>

                <div class="border-t border-slate-100 pt-4 space-y-3">
                    <label class="block text-sm font-semibold text-slate-700">Add Comment</label>
                    <textarea x-model="commentBody" rows="3" class="input-field" placeholder="Share updates or ask for more info..."></textarea>
                    <button type="button" @@click="submitComment()" class="btn btn-primary w-full sm:w-auto">Post Comment</button>
                </div>
            </div>
        </div>

        <!-- Sidebar Details -->
        <aside class="space-y-6">
            <!-- Quick Actions -->
            <div class="card p-6 bg-primary-600 border-none shadow-lg shadow-primary-200 text-white">
                <h3 class="text-sm font-bold uppercase tracking-wider mb-4 text-primary-100">Quick Actions</h3>
                <div class="space-y-2">
                    <button @@click="newStatus = 'InProgress'; showStatusModal = true; statusNote = ''" class="w-full btn bg-white/10 hover:bg-white/20 text-white border-none py-2.5">Start Working</button>
                    <button @@click="newStatus = 'Resolved'; showStatusModal = true; statusNote = ''" class="w-full btn bg-white/10 hover:bg-white/20 text-white border-none py-2.5">Resolve Request</button>
                    <button @@click="newStatus = 'Rejected'; showStatusModal = true; statusNote = ''" class="w-full btn bg-white/10 hover:bg-white/20 text-white border-none py-2.5">Reject</button>
                </div>
            </div>

            <!-- Details Card -->
            <div class="card p-6 space-y-6">
                <div>
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Department</h4>
                    <p class="text-sm font-semibold text-slate-900">@Model.Department.Name</p>
                    <div class="mt-3 space-y-2">
                        @foreach (var member in Model.Department.Members)
                        {
                            <div class="text-xs text-slate-600 flex items-center justify-between border border-slate-100 rounded-lg px-3 py-2">
                                <span>@member.FullName</span>
                                <span class="text-slate-400">@member.Email</span>
                            </div>
                        }
                        @if (!Model.Department.Members.Any())
                        {
                            <span class="text-xs text-slate-400">No members registered.</span>
                        }
                    </div>
                </div>

                <div>
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Participants</h4>
                    <div class="space-y-4">
                        <div class="flex items-center">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 text-xs font-bold mr-3">RQ</div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">@Model.Requester.Name</p>
                                <p class="text-xs text-slate-500">Requester</p>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Recipient.Name))
                        {
                            <div class="flex items-center">
                                <div class="w-8 h-8 rounded-full bg-primary-50 flex items-center justify-center text-primary-600 text-xs font-bold mr-3">AS</div>
                                <div>
                                    <p class="text-sm font-bold text-slate-900">@Model.Recipient.Name</p>
                                    <p class="text-xs text-slate-500">Assigned To</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="pt-6 border-t border-slate-100 space-y-4">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500">Created</span>
                        <span class="font-medium text-slate-900">@Model.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</span>
                    </div>
                    @if (Model.DueAtUtc.HasValue)
                    {
                        <div class="flex justify-between text-sm">
                            <span class="text-slate-500">Deadline</span>
                            <span class="font-medium text-red-600">@Model.DueAtUtc.Value.ToLocalTime().ToString("MMM dd, yyyy")</span>
                        </div>
                    }
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500">Source</span>
                        <span class="font-medium text-slate-900">@Model.Metadata.Channel</span>
                    </div>
                </div>
            </div>

            <div class="card p-6 space-y-4">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Your Identity</h4>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-500">Full Name</label>
                        <input type="text" x-model="actor.name" class="input-field mt-1" placeholder="Jane Doe">
                    </div>
                    <div>
                        <label class="text-xs text-slate-500">Email</label>
                        <input type="email" x-model="actor.email" class="input-field mt-1" placeholder="jane@example.com">
                    </div>
                    <div>
                        <label class="text-xs text-slate-500">I am the</label>
                        <select x-model="actor.actorType" class="input-field mt-1">
                            <option value="Requester">Requester</option>
                            <option value="DepartmentMember">Department Member</option>
                        </select>
                    </div>
                    <button type="button" class="btn btn-secondary w-full" @@click="persistActor()">Remember details</button>
                </div>
            </div>
        </aside>
    </div>

    <!-- Status Update Modal (Alpine.js) -->
    <div x-show="showStatusModal" 
         class="fixed inset-0 z-[100] overflow-y-auto" 
         style="display: none;">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div x-show="showStatusModal" 
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"
                 class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" @@click="showStatusModal = false"></div>

            <div x-show="showStatusModal"
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-primary-100 text-primary-600 sm:mx-0 sm:h-10 sm:w-10">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                        </div>
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                            <h3 class="text-lg leading-6 font-bold text-slate-900">Update Status to <span x-text="newStatus" class="text-primary-600"></span></h3>
                            <div class="mt-4">
                                <label class="block text-sm font-medium text-slate-700 mb-2">Internal Note</label>
                                <textarea x-model="statusNote" rows="3" class="input-field" placeholder="Brief explanation of the status change..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse gap-3">
                    <button @@click="updateStatus()" class="btn btn-primary w-full sm:w-auto">Update Status</button>
                    <button @@click="showStatusModal = false" class="btn btn-secondary w-full sm:w-auto mt-2 sm:mt-0">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>
