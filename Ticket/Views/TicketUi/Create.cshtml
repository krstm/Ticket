@{
    ViewData["Title"] = "New Request";
    var categories = ViewBag.Categories as IEnumerable<Ticket.DTOs.Responses.CategoryDto> ?? Enumerable.Empty<Ticket.DTOs.Responses.CategoryDto>();
}

<div class="max-w-2xl mx-auto" x-data="{
    form: {
        title: '',
        description: '',
        priority: 'Medium',
        categoryId: '',
        requester: { name: '', email: '', phone: '' },
        metadata: { channel: 'Web' }
    },
    isSubmitting: false,
    async submitForm() {
        if(!this.form.title || !this.form.categoryId) {
            alert('Please fill in the title and category.');
            return;
        }
        this.isSubmitting = true;
        try {
            const response = await fetch('/tickets', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.form)
            });
            if(response.ok) {
                const data = await response.json();
                window.location = `/ui/tickets/${data.id}`;
            } else {
                const error = await response.json();
                alert('Error: ' + (error.detail || 'Failed to create request'));
            }
        } catch(e) { console.error(e); }
        finally { this.isSubmitting = false; }
    }
}">
    <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Create New Request</h2>
        <p class="mt-2 text-slate-500">Provide the details below to initiate a new support or service request.</p>
    </div>

    <form @@submit.prevent="submitForm()" class="space-y-8">
        <!-- Basic Info Section -->
        <div class="card p-8 space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest border-b border-slate-100 pb-4">Basic Information</h3>
            
            <div class="grid grid-cols-1 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Request Title</label>
                    <input type="text" x-model="form.title" placeholder="e.g., Requesting a new office chair" class="input-field" required>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Category</label>
                        <select x-model="form.categoryId" class="input-field" required>
                            <option value="">Select Category</option>
                            @foreach(var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Priority</label>
                        <select x-model="form.priority" class="input-field">
                            @foreach(Ticket.Domain.Enums.TicketPriority p in Enum.GetValues(typeof(Ticket.Domain.Enums.TicketPriority)))
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description Section -->
        <div class="card p-8 space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest border-b border-slate-100 pb-4">Details</h3>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Description</label>
                <textarea x-model="form.description" rows="5" class="input-field" placeholder="Describe the request in detail..."></textarea>
            </div>
        </div>

        <!-- Requester Section -->
        <div class="card p-8 space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest border-b border-slate-100 pb-4">Requester Information</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
                    <input type="text" x-model="form.requester.name" placeholder="John Doe" class="input-field">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Email Address</label>
                    <input type="email" x-model="form.requester.email" placeholder="john@example.com" class="input-field">
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="flex items-center justify-end space-x-4 pt-4">
            <a asp-controller="TicketUi" asp-action="Index" class="btn btn-secondary px-6 py-3">Cancel</a>
            <button type="submit" 
                    :disabled="isSubmitting"
                    class="btn btn-primary px-10 py-3 shadow-lg shadow-primary-200 disabled:opacity-50">
                <span x-show="!isSubmitting">Create Request</span>
                <span x-show="isSubmitting" class="flex items-center">
                    <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    Processing...
                </span>
            </button>
        </div>
    </form>
</div>
