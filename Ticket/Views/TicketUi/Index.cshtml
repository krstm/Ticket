@model Ticket.DTOs.Responses.PagedResult<Ticket.DTOs.Responses.TicketSummaryDto>
@using Ticket.Domain.Enums
@{
    ViewData["Title"] = "All Requests";
    var categories = ViewBag.Categories as IEnumerable<Ticket.DTOs.Responses.CategoryDto> ?? Enumerable.Empty<Ticket.DTOs.Responses.CategoryDto>();

    string GetPriorityClass(TicketPriority priority) => priority switch
    {
        TicketPriority.Critical => "text-red-700 bg-red-50 ring-red-600/20",
        TicketPriority.High => "text-orange-700 bg-orange-50 ring-orange-600/20",
        TicketPriority.Medium => "text-blue-700 bg-blue-50 ring-blue-600/20",
        _ => "text-slate-600 bg-slate-50 ring-slate-500/10"
    };

    string GetStatusDot(TicketStatus status) => status switch
    {
        TicketStatus.New => "bg-blue-500",
        TicketStatus.InProgress => "bg-amber-500",
        TicketStatus.Resolved => "bg-emerald-500",
        TicketStatus.Closed => "bg-slate-500",
        TicketStatus.Rejected => "bg-rose-500",
        _ => "bg-slate-300"
    };
}

<div class="flex flex-col lg:flex-row gap-8" x-data="{ 
    filtersOpen: false,
    search: '@(Context.Request.Query["SearchTerm"])',
    priority: '@(Context.Request.Query["Priority"])',
    status: '@(Context.Request.Query["Status"])',
    category: '@(Context.Request.Query["CategoryId"])',
    submitFilters() {
        let url = new URL(window.location);
        if(this.search) url.searchParams.set('SearchTerm', this.search); else url.searchParams.delete('SearchTerm');
        if(this.priority) url.searchParams.set('Priority', this.priority); else url.searchParams.delete('Priority');
        if(this.status) url.searchParams.set('Status', this.status); else url.searchParams.delete('Status');
        if(this.category) url.searchParams.set('CategoryId', this.category); else url.searchParams.delete('CategoryId');
        url.searchParams.delete('PageToken'); // Reset pagination on filter change
        window.location = url;
    }
}">
    <!-- Filter Sidebar (Desktop) / Modal (Mobile) -->
    <aside class="w-full lg:w-64 flex-shrink-0">
        <div class="card p-6 sticky top-24">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider">Filters</h3>
                <button @@click="submitFilters()" class="text-xs font-bold text-primary-600 hover:text-primary-700">Apply</button>
            </div>

            <div class="space-y-6">
                <!-- Search -->
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-2">Keyword</label>
                    <input type="text" x-model="search" @@keydown.enter="submitFilters()" placeholder="Search..." class="input-field py-2">
                </div>

                <!-- Category -->
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-2">Category</label>
                    <select x-model="category" class="input-field py-2">
                        <option value="">All Categories</option>
                        @foreach(var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <!-- Priority -->
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-2">Priority</label>
                    <div class="space-y-2">
                        @foreach(TicketPriority p in Enum.GetValues(typeof(TicketPriority)))
                        {
                            <label class="flex items-center text-sm text-slate-600 cursor-pointer hover:text-slate-900">
                                <input type="radio" x-model="priority" value="@p" class="w-4 h-4 text-primary-600 border-slate-300 focus:ring-primary-500 mr-2">
                                @p
                            </label>
                        }
                        <label class="flex items-center text-sm text-slate-600 cursor-pointer hover:text-slate-900">
                            <input type="radio" x-model="priority" value="" class="w-4 h-4 text-primary-600 border-slate-300 focus:ring-primary-500 mr-2">
                            Any
                        </label>
                    </div>
                </div>

                <!-- Status -->
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-2">Status</label>
                    <select x-model="status" class="input-field py-2">
                        <option value="">Any Status</option>
                        @foreach(TicketStatus s in Enum.GetValues(typeof(TicketStatus)))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </aside>

    <!-- Results Area -->
    <div class="flex-1 min-w-0">
        <div class="mb-6 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">
                @if(Model.TotalCount.HasValue) {
                    <span>@Model.TotalCount Results</span>
                } else {
                    <span>Found Results</span>
                }
            </h2>
            
            <div class="flex items-center space-x-2">
                <span class="text-xs text-slate-400">Sort by:</span>
                <select class="bg-transparent border-none text-xs font-semibold text-slate-600 focus:ring-0 cursor-pointer">
                    <option>Newest First</option>
                    <option>Highest Priority</option>
                    <option>Deadline</option>
                </select>
            </div>
        </div>

        <div class="space-y-4">
            @if(!Model.Items.Any())
            {
                <div class="text-center py-20 bg-white rounded-xl border border-dashed border-slate-200">
                    <p class="text-slate-400">No requests found matching your filters.</p>
                </div>
            }

            @foreach (var ticket in Model.Items)
            {
                <div class="card group hover:border-primary-200 transition-all p-4 sm:p-5">
                    <div class="flex items-start gap-4">
                        <!-- Status Marker -->
                        <div class="mt-1 flex-shrink-0 w-2.5 h-2.5 rounded-full @GetStatusDot(ticket.Status) shadow-sm ring-4 ring-white shadow-current"></div>
                        
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between gap-4 mb-1">
                                <h3 class="text-base font-bold text-slate-900 group-hover:text-primary-600 transition-colors truncate">
                                    <a asp-controller="TicketUi" asp-action="Details" asp-route-id="@ticket.Id">@ticket.Title</a>
                                </h3>
                                <span class="badge @GetPriorityClass(ticket.Priority) ring-1 ring-inset">@ticket.Priority</span>
                            </div>

                            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-500">
                                <span class="font-medium text-slate-700">@ticket.ReferenceCode</span>
                                <span class="text-slate-300">•</span>
                                <span class="flex items-center">
                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 11h.01M7 15h.01M11 7h.01M11 11h.01M11 15h.01M15 7h.01M15 11h.01M15 15h.01M19 7h.01M19 11h.01M19 15h.01M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                    @ticket.CategoryName
                                </span>
                                <span class="text-slate-300">•</span>
                                <span>Created @ticket.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                            </div>
                        </div>

                        <div class="hidden sm:flex flex-shrink-0">
                            <a asp-controller="TicketUi" asp-action="Details" asp-route-id="@ticket.Id" class="p-2 text-slate-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (!string.IsNullOrEmpty(Model.NextPageToken))
        {
            <div class="mt-10 flex justify-center">
                <a href="?PageToken=@Model.NextPageToken" class="btn btn-secondary px-8">
                    Load More
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7m14-8l-7 7-7-7"/></svg>
                </a>
            </div>
        }
        else if (Model.Items.Any())
        {
            <div class="mt-10 text-center">
                <p class="text-sm text-slate-400 italic">No more requests to show.</p>
            </div>
        }
    </div>
</div>
