@{
    ViewData["Title"] = "New Category";
}

<div class="max-w-2xl mx-auto" x-data="{
    form: {
        name: '',
        description: ''
    },
    isSubmitting: false,
    async submitForm() {
        if(!this.form.name) {
            alert('Please enter a category name.');
            return;
        }
        this.isSubmitting = true;
        try {
            const response = await fetch('/categories', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.form)
            });
            if(response.ok) {
                window.location = '/ui/categories';
            } else {
                const error = await response.json();
                alert('Error: ' + (error.detail || 'Failed to create category'));
            }
        } catch(e) { console.error(e); }
        finally { this.isSubmitting = false; }
    }
}">
    <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Create New Category</h2>
        <p class="mt-2 text-slate-500">Define a new category to group related support requests.</p>
    </div>

    <form @@submit.prevent="submitForm()" class="space-y-8">
        <div class="card p-8 space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest border-b border-slate-100 pb-4">Category Details</h3>
            
            <div class="grid grid-cols-1 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Category Name</label>
                    <input type="text" x-model="form.name" placeholder="e.g., Human Resources" class="input-field" required maxlength="150">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Description (Optional)</label>
                    <textarea x-model="form.description" rows="3" class="input-field" placeholder="Brief explanation of what this category covers..." maxlength="500"></textarea>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="flex items-center justify-end space-x-4 pt-4">
            <a asp-controller="CategoryUi" asp-action="Index" class="btn btn-secondary px-6 py-3">Cancel</a>
            <button type="submit" 
                    :disabled="isSubmitting"
                    class="btn btn-primary px-10 py-3 shadow-lg shadow-primary-200 disabled:opacity-50">
                <span x-show="!isSubmitting">Create Category</span>
                <span x-show="isSubmitting" class="flex items-center">
                    <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    Processing...
                </span>
            </button>
        </div>
    </form>
</div>
